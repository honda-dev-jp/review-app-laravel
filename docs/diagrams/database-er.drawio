        </mxCell>
        <mxCell id="Q8vbwcxx8VyzVfylaDMl-129" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=17;fontColor=#FF0000;" value="&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;設計メモ&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;-------------------------&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- reviews.rating が評価データの正&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- items.rating / rating_count は表示高速化用キャッシュ&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- reviews.user_id は退会時 NULL&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- review_comments.user_id は退会時 NULL&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- 退会ユーザーの投稿者名は「匿名」と表示&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- レビュー削除時は review_comments も削除&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- レビュー削除後は items.rating / rating_count を再計算&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0); font-size: 14px;&quot;&gt;- parent_id は将来用。初期フェーズでは常に NULL&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="360" x="440" y="673" as="geometry" />
        </mxCell>
        <mxCell id="Q8vbwcxx8VyzVfylaDMl-130" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="&lt;div&gt;リレーション補足&lt;/div&gt;&lt;div&gt;-------------------------&lt;/div&gt;&lt;div&gt;- categories 1 : N items&lt;/div&gt;&lt;div&gt;- items 1 : N reviews&lt;/div&gt;&lt;div&gt;- users 0..1 : N reviews&lt;/div&gt;&lt;div&gt;- reviews 1 : N review_comments&lt;/div&gt;&lt;div&gt;- users 0..1 : N review_comments&lt;/div&gt;&lt;div&gt;- review_comments 0..1 : N review_comments（将来用）&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="380" x="420" y="920" as="geometry" />
        </mxCell>
        <mxCell id="Q8vbwcxx8VyzVfylaDMl-131" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="&lt;div&gt;インデックス設計&lt;/div&gt;&lt;div&gt;----------------&lt;/div&gt;&lt;div&gt;- reviews(item_id, created_at)&lt;/div&gt;&lt;div&gt;&amp;nbsp; 作品詳細画面でレビューを取得するため&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- review_comments(review_id, created_at)&lt;/div&gt;&lt;div&gt;&amp;nbsp; レビューに紐づく返信コメントを取得するため&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;- review_comments(parent_id)&lt;/div&gt;&lt;div&gt;&amp;nbsp; 将来の階層返信に備えるため&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="380" x="10" y="1080" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
